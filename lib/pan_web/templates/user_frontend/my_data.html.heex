<h1 class="text-3xl">
  My Data
</h1>

<p class="mt-8 mb-4">
  <div class="float-right">
    Manage &nbsp;
    <.link href={user_frontend_path(@conn, :my_profile)} target="_blank" class="border border-gray-darker text-gray-darkest hover:bg-gray-lighter py-2 px-3 rounded-md">
      {icon("user-circle-heroicons-outline")} My Profile
    </.link>
  </div>
  <h2 class="text-2xl">Account</h2>
</p>

<p class="my-4">
  <.link href={user_json_download_path(@conn, :download)} class="border border-gray btn btn-primary">
    {icon("document-download-heroicons-outline")} Download
  </.link> all my data as JSON-File
</p>

<dl class="grid grid-cols-2 gap-x-4 max-w-4xl">
  <dt class="text-right">Name</dt>
  <dd><%= @user.name %></dd>
  <dt class="text-right">Username</dt>
  <dd><%= @user.username %></dd>
  <dt class="text-right">Email</dt>
  <dd><%= @user.email %></dd>
  <dt class="text-right">Email adress confirmed?</dt>
  <dd><%= @user.email_confirmed %></dd>
  <dt class="text-right">Is podcaster?</dt>
  <dd><%= @user.podcaster %></dd>
  <dt class="text-right">Shares subscriptions?</dt>
  <dd><%= @user.share_subscriptions %></dd>
  <dt class="text-right">Shares follows?</dt>
  <dd><%= @user.share_follows %></dd>
  <dt class="text-right">Pro account until</dt>
  <dd><%= if @user.pro_until, do: Calendar.strftime(@user.pro_until, "%x %H:%M") %></dd>
  <dt class="text-right">Billing address</dt>
  <dd>
    <pre class="text-mono p-2 border border-gray-dark bg-gray-lighter"><%= @user.billing_address %>
    </pre>
  </dd>
  <dt class="text-right">Payment reference</dt>
  <dd><%= @user.payment_reference %></dd>
  <dt class="text-right">Wants a paper bill?</dt>
  <dd><%= @user.paper_bill %></dd>
</dl>

<div class="mt-8 mb-4">
  <div class="float-right">
    Manage &nbsp;
    <.link href={opml_frontend_path(@conn, :index)} target="_blank" class="border border-gray-darker text-gray-darkest hover:bg-gray-lighter py-2 px-3 rounded-md">
      {icon("document-download-heroicons-outline")} My OPMLs
    </.link>
  </div>
  <h2 class="text-2xl">OPML Files</h2>
</div>

<ul class="list-disc ml-4">
  <%= for opml <- @user.opmls do %>
    <li><%= opml.filename %></li>
  <% end %>
</ul>

<h2 class="text-2xl mb-4 mt-8">Personas</h2>
You can even delete all manifestations as personas, you created so far, at once, by clicking
&nbsp;
<.link href={manifestation_frontend_path(@conn, :delete_all)} method="delete" data-confirm="Are you sure? All manifestations will be deleted!" class="btn btn-error whitespace-nowrap leading-10">
  {icon("exclamation-heroicons-outline")} Delete all manifestations
</.link>

<%= for persona <- @user.personas do %>
  <h3 class="text-xl my-4">
    Persona <%= persona.name %>
    <.link href={manifestation_frontend_path(@conn, :delete, persona.id)} method="delete" data-confirm="Are you sure?" class="border border-gray bg-danger hover:bg-danger-light text-sm text-white py-1 px-2 rounded-md whitespace-nowrap">Delete Manifestation</.link>
  </h3>

  <dl class="grid grid-cols-2 gap-x-6 max-w-2xl">
    <dt class="text-right">PanoptikumID</dt>
    <dd><%= persona.pid %></dd>
    <dt class="text-right">Name</dt>
    <dd><%= persona.name %></dd>
    <dt class="text-right">Uri</dt>
    <dd><%= persona.uri %></dd>
    <dt class="text-right">Email</dt>
    <dd><%= persona.email %></dd>
    <dt class="text-right">Description</dt>
    <dd><%= persona.description %></dd>
    <dt class="text-right">Url</dt>
    <dd><%= persona.image_url %></dd>
    <dt class="text-right">Title</dt>
    <dd><%= persona.image_title %></dd>
  </dl>
<% end %>

<%= for persona <- @user.user_personas do %>
  <h3 class="text-xl my-4">
    Persona <%= persona.name %>
    <.link href={persona_frontend_path(@conn, :disconnect, persona.id)} method="post" data-confirm="Are you sure?" class="border border-gray bg-danger hover:bg-danger-light text-sm text-white py-1 px-2 rounded-md whitespace-nowrap">Disconnect Persona</.link>
  </h3>

  <dl class="grid grid-cols-2 gap-x-6 max-w-2xl">
    <dt class="text-right">PanoptikumID</dt>
    <dd><%= persona.pid %></dd>
    <dt class="text-right">Name</dt>
    <dd><%= persona.name %></dd>
    <dt class="text-right">Uri</dt>
    <dd><%= persona.uri %></dd>
    <dt class="text-right">Email</dt>
    <dd><%= persona.email %></dd>
    <dt class="text-right">Description</dt>
    <dd><%= persona.description %></dd>
    <dt class="text-right">Url</dt>
    <dd><%= persona.image_url %></dd>
    <dt class="text-right">Title</dt>
    <dd><%= persona.image_title %></dd>
  </dl>
<% end %>

<h2 class="text-2xl mb-4 mt-8">Invoices</h2>
Invoices cannot be deleted, we have to store them due to fiscal regulations.
<%= for invoice <- @user.invoices do %>
  <dl class="grid grid-cols-2 gap-x-6 max-w-2xl">
    <dt class="text-right">Date</dt>
    <dd><%= Calendar.strftime(invoice.inserted_at, "%x %H:%M") %></dd>
    <dt class="text-right">File</dt>
    <dd><.link href={invoice_frontend_path(@conn, :download, invoice)}>{invoice.filename}</.link></dd>
  </dl>
  <br />
<% end %>

<h2 class="text-2xl mb-4 mt-8">Subscribed Podcasts</h2>

<p class="mb-2">
  Click on the podcast link to open the podcast show page in a new tab to un/like, un/subscribe, un/follow.
</p>
You can even delete all the subscriptions, you created so far, at once, by clicking &nbsp;
<.link href={subscription_frontend_path(@conn, :delete_all)} method="delete" data-confirm="Are you sure? All subscriptions will be deleted!" class="btn btn-error whitespace-nowrap leading-10">
  {icon("exclamation-heroicons-outline")} Delete all subscriptions
</.link>

<ul class="list-disc m-4">
  <%= for podcast <- @user.podcasts_i_subscribed do %>
    <li>
      <.link href={podcast_frontend_path(@conn, :show, podcast)} target="_blank" class="text-link hover:text-link-dark">{podcast.title}</.link>
    </li>
  <% end %>
</ul>

