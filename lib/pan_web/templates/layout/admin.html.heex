<main role="main" class="bg-gray-lightest mb-4 min-h-screen text-black">
  <div class="alert-info empty:hidden m-4" role="alert"><%= Phoenix.Flash.get(@flash, :info) %></div>
  <div class="alert-danger empty:hidden m-4" role="alert"><%= Phoenix.Flash.get(@flash, :error) %></div>
  <%= @inner_content %>
</main>
